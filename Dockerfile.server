# ============================================================
# tdpadmin — Backend server (server.cjs)
# ============================================================
FROM node:22-alpine
WORKDIR /app

# Dependencies
COPY package.json package-lock.json ./
RUN npm ci --omit=dev

# Código
COPY server.cjs ./
COPY public ./public

# Puerto
EXPOSE 3003

# Inicio
CMD ["node", "server.cjs"]
