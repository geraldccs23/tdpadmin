# ============================================================
# restaurantdp — Backend server (server.cjs)
# ============================================================
FROM node:22-alpine
WORKDIR /app

# Dependencies: solo pg, dotenv, express (ya en package.json)
COPY package.json package-lock.json ./
RUN npm ci --omit=dev

# Código
COPY server.cjs ./

# Puerto
EXPOSE 3003

# Inicio
CMD ["node", "server.cjs"]
