# Frontend (Vite — aún usa Supabase client, se migrará después)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend API (data proxy — reemplaza supabase.from gradualmente)
VITE_API_URL=https://api.restaurant.tallerdepixeles.com
VITE_API_KEY=change_me

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key

# CRM Backend (Evolution API bridge)
VITE_CRM_API_URL=http://localhost:3001
VITE_CRM_API_KEY=key-para-frontend

# Agent API (Integraciones, Mercatech, etc)
VITE_AGENT_API_URL=https://admin.tudominio.com/

# JWT Secret (para firmar tokens de autenticación)
JWT_SECRET=change_me

# Server (node server.cjs)
PORT=3003

# PostgreSQL (Docker hostname: postgres)
PGHOST=postgres
PGPORT=5432
PGDATABASE=tdp_main
PGUSER=tdp_admin
PGPASSWORD=change_me

# Admin API Token (para rutas de administración de tokens)
ADMIN_API_TOKEN=change_me

# Agent Token (para agentes externos como Mercatech)
AGENT_TOKEN=change_me

# Redis
REDIS_URL=redis://redis:6379

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=change_me
MINIO_SECRET_KEY=change_me

# Admin TDP Central (futura sincronización de soporte)
TDP_ADMIN_API_URL=
TDP_ADMIN_API_TOKEN=
TDP_TENANT_ID=restaurantdp

# Uploads (directorio donde se guardan archivos de soporte)
UPLOAD_DIR=./uploads
