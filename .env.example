# TDP Admin — Variables de Entorno
# =============================================================================

# Frontend
VITE_API_URL=https://api.admin.tallerdepixeles.com

# Backend
PORT=3003
JWT_SECRET=change_me_secure_random

# PostgreSQL (tdp_main — datos heredados de restaurante)
PGHOST=postgres
PGPORT=5432
PGDATABASE=tdp_main
PGUSER=tdp_admin
PGPASSWORD=change_me

# PostgreSQL (tdpadmin — datos propios de TDP Admin)
# Usar DATABASE_URL sobreescribe PGHOST/PGPORT/PGDATABASE/PGUSER/PGPASSWORD para el pool tdpadmin
DATABASE_URL=postgresql://tdp_lidel:CHANGE_ME@postgres:5432/tdpadmin

# Public API Token (para soporte externo — RG7)
PUBLIC_API_TOKEN=change_me

# Admin API Token (para data proxy legacy)
ADMIN_API_TOKEN=change_me

# Agent Token (para agentes legacy)
AGENT_TOKEN=change_me

# Redis
REDIS_URL=redis://redis:6379

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=change_me
MINIO_SECRET_KEY=change_me

# Admin TDP Central (futura sincronización)
TDP_ADMIN_API_URL=
TDP_ADMIN_API_TOKEN=
TDP_TENANT_ID=tdpadmin

# Uploads
UPLOAD_DIR=./uploads
PUBLIC_UPLOAD_DIR=./public_uploads
