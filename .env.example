# TDP Admin — Variables de Entorno
# =============================================================================

# Frontend (Vite)
VITE_API_URL=https://api.tallerdepixeles.com

# Backend
PORT=3003
JWT_SECRET=change_me

# PostgreSQL
PGHOST=postgres
PGPORT=5432
PGDATABASE=tdp_main
PGUSER=tdp_admin
PGPASSWORD=change_me

# Admin API Token
ADMIN_API_TOKEN=change_me

# Agent Token
AGENT_TOKEN=change_me

# Redis
REDIS_URL=redis://redis:6379

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=change_me
MINIO_SECRET_KEY=change_me

# Admin TDP Central (futura sincronización)
TDP_ADMIN_API_URL=
TDP_ADMIN_API_TOKEN=
TDP_TENANT_ID=tdpadmin

# Uploads
UPLOAD_DIR=./uploads
